# Copy this file to .env and fill in the values. .env is gitignored.

# ---- Firebase web config (PUBLIC by design — safe in the client bundle) ----
# A Firebase web API key identifies the project; it does not grant access.
# Access is controlled by Firebase Auth + Firestore/Storage security rules.
# Get these from Firebase console -> Project settings -> your web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Multi-database projects only; leave blank to use "(default)".
VITE_FIREBASE_FIRESTORE_DB_ID=

# ---- Real SECRETS — never commit these ----
# Server-side Gemini key (Google AI Studio -> API keys). Without it the AI
# endpoints run in deterministic simulated mode.
GEMINI_API_KEY=

# Google Maps Platform key. Baked into the client at BUILD time by Vite, so it
# must be present when `npm run build` runs (or passed as a Docker build arg).
# Without it the map renders a disabled state.
VITE_GOOGLE_MAPS_API_KEY=

# ---- 3-role system ----
# Firebase UID of the admin user (copy your UID from the app header after first login).
VITE_ADMIN_UID=
# Secret code cleaners enter in the Leaderboard tab to unlock the cleaner role.
VITE_CLEANER_CODE=CLEAN2026
# Minimum matching votes (clean OR dirty) needed to resolve/reject a cleanup claim.
VITE_VERIFY_THRESHOLD=2
